{
  "$schema": "https://nitro.margelo.com/nitro.schema.json",
  "cxxNamespace": ["genyt", "extractor"],
  "android": {
    "androidNamespace": ["genyt", "extractor"],
    "androidCxxLibName": "NitroGenytYoutubeExtractor"
  },
  "ios": {
    "iosModuleName": "NitroGenytYoutubeExtractor"
  },
  "autolinking": {
    "YoutubeExtractor": {
      "android": {
        "language": "kotlin",
        "implementationClassName": "HybridYoutubeExtractor"
      }
    }
  },
  "ignorePaths": [
    "**/node_modules"
  ]
}
